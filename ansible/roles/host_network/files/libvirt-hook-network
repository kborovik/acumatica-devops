#!/usr/bin/env bash
# /etc/libvirt/hooks/network — managed by ansible (host_network role).
#
# Libvirt re-inserts its FORWARD chains (which reject unsolicited traffic
# into virbr0) at the top of the chain every time the network starts, so
# the tailnet->VM allow rule must be (re)inserted above them on each start.
set -euo pipefail

NET=$1 OP=$2

if [[ $NET == default && $OP == started ]]; then
    iptables -C FORWARD -i tailscale0 -o virbr0 -j ACCEPT 2>/dev/null || \
        iptables -I FORWARD 1 -i tailscale0 -o virbr0 -j ACCEPT
fi
