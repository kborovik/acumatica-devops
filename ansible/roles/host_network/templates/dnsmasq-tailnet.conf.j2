# Managed by Ansible (host_network role) — do not edit.
# DNS-only dnsmasq on the tailscale interface: resolves VM names under
# {{ vm_dns_domain }} for tailnet clients (wired up via Tailscale split DNS).
# Records come from vm_dhcp_hosts in group_vars/all.yml.
user=dnsmasq
bind-dynamic
interface=tailscale0
except-interface=lo
no-resolv
no-hosts
local=/{{ vm_dns_domain }}/
{% for host in vm_dhcp_hosts %}
host-record={{ host.name }}.{{ vm_dns_domain }},{{ host.ip }}
{% endfor %}
