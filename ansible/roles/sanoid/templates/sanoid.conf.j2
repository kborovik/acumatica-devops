# Snapshot policy for kronos (sanoid role). Sanoid reads this on every
# sanoid.timer run (15 min) and only ever prunes its own autosnap_* snapshots —
# manually named snapshots are never touched.
#
# daily_hour/daily_min keep the pre-sanoid nightly timeline: the 02:00 in-guest
# SQL Agent .bak job finishes well before the 03:15 share snapshot; VM zvols
# follow at 03:30.
#
# recursive = zfs takes ONE atomic `zfs snapshot -r` per run — every descendant
# zvol at the same txg — so a VM's OS, data, and backup disks stay mutually
# consistent, and new VMs are auto-included.

[{{ vm_zvol_parent }}]
    use_template = vms
    recursive = zfs

[{{ mssql_backup_dataset }}]
    use_template = backups

[template_vms]
    frequently = 0
    hourly = 0
    daily = {{ vm_snap_keep }}
    weekly = 0
    monthly = 0
    yearly = 0
    autosnap = yes
    autoprune = yes
    daily_hour = 3
    daily_min = 30

[template_backups]
    frequently = 0
    hourly = 0
    daily = {{ backup_snap_keep }}
    weekly = 0
    monthly = 0
    yearly = 0
    autosnap = yes
    autoprune = yes
    daily_hour = 3
    daily_min = 15
