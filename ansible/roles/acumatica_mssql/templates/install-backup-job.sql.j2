-- Managed by Ansible (roles/acumatica_mssql). Idempotent: drops and recreates the job so
-- edits here converge on the guest. Single batch (no GO) — executed via SqlClient.
USE msdb;

IF EXISTS (SELECT 1 FROM dbo.sysjobs WHERE name = N'{{ mssql_backup_job_name }}')
    EXEC dbo.sp_delete_job @job_name = N'{{ mssql_backup_job_name }}', @delete_unused_schedule = 1;

IF EXISTS (SELECT 1 FROM dbo.sysschedules WHERE name = N'{{ mssql_backup_job_name }} daily')
    EXEC dbo.sp_delete_schedule @schedule_name = N'{{ mssql_backup_job_name }} daily', @force_delete = 1;

EXEC dbo.sp_add_job
     @job_name = N'{{ mssql_backup_job_name }}',
     @enabled = 1,
     @owner_login_name = N'sa',
     @description = N'Nightly BACKUP of every user database to the local backup disk, then copy to the mssql-backups SMB share.';

-- Step 1: back up each online, non-snapshot user database to the local disk.
EXEC dbo.sp_add_jobstep
     @job_name = N'{{ mssql_backup_job_name }}',
     @step_id = 1,
     @step_name = N'Backup user databases (local)',
     @subsystem = N'TSQL',
     @database_name = N'master',
     @on_success_action = 3,   -- go to next step
     @on_fail_action = 2,      -- quit reporting failure
     @command = N'SET NOCOUNT ON;
DECLARE @db sysname, @f nvarchar(400);
DECLARE c CURSOR LOCAL FAST_FORWARD FOR
  SELECT name FROM sys.databases
  WHERE database_id > 4 AND state = 0 AND source_database_id IS NULL;
OPEN c; FETCH NEXT FROM c INTO @db;
WHILE @@FETCH_STATUS = 0
BEGIN
  SET @f = N''{{ mssql_backup_local_dir }}\'' + @db + N''.bak'';
  BACKUP DATABASE @db TO DISK = @f WITH INIT, COMPRESSION, CHECKSUM;
  FETCH NEXT FROM c INTO @db;
END
CLOSE c; DEALLOCATE c;';

-- Step 2: copy the .bak files to the SMB share (authenticates as {{ smb_backup_user }}).
EXEC dbo.sp_add_jobstep
     @job_name = N'{{ mssql_backup_job_name }}',
     @step_id = 2,
     @step_name = N'Copy to SMB share',
     @subsystem = N'CmdExec',
     @on_success_action = 1,   -- quit reporting success
     @on_fail_action = 2,      -- quit reporting failure
     @command = N'"{{ mssql_backup_script_dir }}\backup-copy.cmd"';

EXEC dbo.sp_add_schedule
     @schedule_name = N'{{ mssql_backup_job_name }} daily',
     @freq_type = 4,           -- daily
     @freq_interval = 1,
     @active_start_time = {{ '%06d' | format(mssql_backup_hour * 10000) }};   -- HHMMSS

EXEC dbo.sp_attach_schedule
     @job_name = N'{{ mssql_backup_job_name }}',
     @schedule_name = N'{{ mssql_backup_job_name }} daily';

EXEC dbo.sp_add_jobserver
     @job_name = N'{{ mssql_backup_job_name }}',
     @server_name = N'(LOCAL)';
